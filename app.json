{
  "expo": {
    "name": "StandUpBro",
    "slug": "sitalert",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "sitalert",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.sitalert.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "StandUpBro uses your location to suppress reminders at saved home or office locations.",
        "NSCalendarsUsageDescription": "StandUpBro checks busy events to suppress inactivity reminders during meetings."
      }
    },
    "android": {
      "package": "com.sitalert.app",
      "adaptiveIcon": {
        "backgroundColor": "#F6EFE3",
        "foregroundImage": "./assets/icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "POST_NOTIFICATIONS",
        "RECEIVE_BOOT_COMPLETED",
        "SCHEDULE_EXACT_ALARM",
        "USE_FULL_SCREEN_INTENT",
        "VIBRATE",
        "WAKE_LOCK",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.READ_CALENDAR",
        "android.permission.WRITE_CALENDAR"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/icon.png"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#D96B2B",
          "sounds": [
            "./assets/sounds/alert.mp3"
          ]
        }
      ],
      "expo-location",
      "expo-calendar",
      "expo-sqlite",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#F6EFE3"
        }
      ],
      "expo-font",
      "expo-asset",
      "expo-router"
    ],
    "experiments": {
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "79101280-7fda-4406-a021-6fcfdb07e141"
      }
    }
  }
}
